<BaseLayout
  title="轉存格常見問題 Q&A · 曠野之息"
  description="《轉存格》IST、DIC、WMC、PE 37個常見問題與 Yuda 的解答，整理自會員質問箱。"
  active="types"
>
  {/* 麵包屑 + 標題 */}
  <section class="border-b border-border-soft">
    <div class="mx-auto max-w-[1180px] px-8 pb-12 pt-[54px]">
      <div class="mb-[22px] flex flex-wrap items-center gap-2 text-[13px] text-muted">
        <a href={href("/")} class="no-underline text-muted">首頁</a>
        <span>/</span>
        <a href={href("/types")} class="no-underline text-muted">常見類型</a>
        <span>/</span>
        <a href={href("/types/botw-02")} class="no-underline text-muted">轉存格</a>
        <span>/</span>
        <span class="text-ink">Q&A</span>
      </div>
      <div class="mb-2 flex items-center gap-2.5">
        <span class="font-mono text-[13px] text-accent">BotW · 02</span>
      </div>
      <h1 class="mb-[18px] font-serif text-[46px] font-medium leading-[1.12] text-ink">
        轉存格常見問題 Q&A
      </h1>
      <p class="text-[17px] text-muted">Inventory Slot Transfer — FAQ</p>
    </div>
  </section>

  {/* 分類說明 */}
  <div class="border-b border-border-soft bg-surface">
    <div class="mx-auto max-w-[1180px] px-8 py-5">
      <div class="flex flex-wrap gap-3 text-[13px]">
        {Object.entries(typeLabel).map(([k, v]) => (
          <span class={`type-badge type-${k.toLowerCase()}`}>{k} · {v}</span>
        ))}
      </div>
    </div>
  </div>

  {/* FAQ 列表 */}
  <article class="mx-auto max-w-[1180px] px-8 pb-20 pt-10">
    <div class="faq-list">
      {faqs.map((item) => (
        <details class="faq-item">
          <summary class="faq-summary">
            <div class="faq-no">{String(item.no).padStart(2, "0")}</div>
            <span class={`type-badge type-${item.type.toLowerCase()}`}>{item.type}</span>
            <div class="faq-q">{item.q}</div>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="faq-answer">
            <Fragment set:html={item.a.includes("<") ? item.a : `<p>${item.a}</p>`} />
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 border-t border-border-soft pt-8">
      <a href={href("/types/botw-02")} class="back-btn inline-flex items-center gap-2 no-underline">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        返回轉存格頁面
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  /* 分類標籤 */
  .type-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font-mono, monospace);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .type-ist  { background: color-mix(in srgb, var(--accent) 15%, transparent); color: var(--accent); }
  .type-dic  { background: color-mix(in srgb, #60a5fa 15%, transparent); color: #60a5fa; }
  .type-wmc  { background: color-mix(in srgb, #c084fc 15%, transparent); color: #c084fc; }
  .type-pe   { background: color-mix(in srgb, #34d399 15%, transparent); color: #34d399; }

  /* FAQ 列表 */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--border-soft);
  }
  .faq-item:first-child {
    border-top: 1px solid var(--border-soft);
  }

  .faq-summary {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px 4px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.1s;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary:hover { background: var(--surface); border-radius: 8px; }

  .faq-no {
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    color: var(--muted);
    min-width: 22px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .faq-q {
    flex: 1;
    font-size: 16px;
    color: var(--ink);
    line-height: 1.55;
    padding-top: 1px;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--muted);
    margin-top: 3px;
    transition: transform 0.2s;
  }
  details[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 4px 4px 20px calc(22px + 14px + 52px + 14px);
    font-size: 15px;
    color: var(--text);
    line-height: 1.75;
  }
  .faq-answer p { margin-bottom: 0.8em; }
  .faq-answer p:last-child { margin-bottom: 0; }
  .faq-answer ol, .faq-answer ul {
    padding-left: 1.5em;
    margin-bottom: 0.8em;
  }
  .faq-answer ol { list-style: decimal; }
  .faq-answer ul { list-style: disc; }
  .faq-answer li { margin-bottom: 0.4em; }
  .faq-answer strong { color: var(--ink); font-weight: 600; }

  :global(.faq-link) {
    color: var(--accent);
    text-underline-offset: 3px;
  }
  :global(.faq-link:hover) { opacity: 0.8; }

  /* 返回按鈕 */
  .back-btn {
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--muted);
    border-radius: 10px;
    padding: 10px 18px;
    font-size: 14px;
    font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
  }
  .back-btn:hover {
    border-color: var(--brand);
    color: var(--brand);
  }

  @media (max-width: 640px) {
    .faq-answer {
      padding-left: 4px;
    }
    .faq-summary {
      flex-wrap: nowrap;
    }
    .faq-no {
      display: none;
    }
  }
</style>
