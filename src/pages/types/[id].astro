---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { href, ytThumb, ytWatch } from "../../lib/url";
import { typeGroups, type TypeItem, type TypeGroup } from "../../data/types";
import { typeContent, type TypeStep, type TermGroup } from "../../data/type-content";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

export function getStaticPaths() {
  const paths: { params: { id: string }; props: { group: TypeGroup; item: TypeItem } }[] = [];
  for (const group of typeGroups) {
    for (const item of group.items) {
      paths.push({
        params: { id: `${group.game}-${item.no}` },
        props: { group, item },
      });
    }
  }
  return paths;
}

const { group, item } = Astro.props;
const { id } = Astro.params as { id: string };
const gameLabelMap: Record<string, string> = {
  botw: "曠野之息",
  totk: "王國之淚",
  eow: "智慧的再現",
  ssbu: "大亂鬥特別版",
};
const gameLabel = gameLabelMap[group.game] ?? group.label;
const content = typeContent[id];

const videoBase = content?.videoFolder
  ? `${BASE}/type-videos/${content.videoFolder}`
  : null;
const imageBase = content?.imageFolder
  ? `${BASE}/type-videos/${content.imageFolder}`
  : null;
const hasAnyVideo = content?.methods?.some((m) => m.video) ?? false;
const hasAnyImage = content?.methods?.some((m) => m.image) ?? false;
const hasMedia = hasAnyVideo || hasAnyImage;

// 只顯示「相關影片」區的分類：隱藏流程／原理／注意事項，
// 並讓影片區延續上方標題區的背景色（不另加 bg-surface）。
const videosOnly = item.videosOnly ?? false;
// 只顯示「名詞說明」＋「相關影片」（大亂鬥用）
const termsOnly = item.termsOnly ?? false;
const isSimpleLayout = videosOnly || termsOnly;
const vidSectionClass = isSimpleLayout ? "" : "border-t border-border-soft bg-surface";
const vidRowHover = isSimpleLayout ? "hover:bg-surface" : "hover:bg-bg";
const vidBtnBg = isSimpleLayout ? "bg-surface" : "bg-bg";

const VIDEOS_PER_PAGE = 10;
const hasDynamicPrinciple = content?.methods?.some((m) => m.principle != null) ?? false;

// 把 __文字__ 解析成可加橙色的片段
function parseAccent(text: string) {
  return text.split("__").map((seg, i) => ({ text: seg, accent: i % 2 === 1 }));
}

// 把步驟正規化為 { text, sub }（純字串視為無子項目）
function stepParts(s: TypeStep) {
  return typeof s === "string"
    ? { text: s, sub: [] as string[] }
    : { text: s.text, sub: s.sub ?? [] };
}

// 把 【人名】 解析成白色底線
function parseName(text: string) {
  return text.split("【").map((part, i) => {
    if (i === 0) return { text: part, name: false };
    const [name, rest] = part.split("】");
    return [{ text: name, name: true }, { text: rest, name: false }];
  }).flat();
}
---

<BaseLayout
  title={`${item.zh} · ${gameLabel}`}
  description={`${item.zh}（${item.en}）攻略說明，${gameLabel}系列。`}
  active="types"
>
  {/* 麵包屑 + 標題 */}
  <section class="border-b border-border-soft">
    <div class="mx-auto max-w-[1180px] px-8 pb-12 pt-[54px]">
      <div class="mb-[22px] flex flex-wrap items-center gap-2 text-[13px] text-muted">
        <a href={href("/")} class="no-underline text-muted">首頁</a>
        <span>/</span>
        <a href={href("/types")} class="no-underline text-muted">主題解說</a>
        <span>/</span>
        <span class="text-ink">{item.zh}</span>
      </div>
      <div class="mb-2 flex items-center gap-2.5">
        <span class="font-mono text-[13px] text-accent">{group.en} · {item.no}</span>
      </div>
      <h1 class="mb-[18px] font-serif text-[46px] font-medium leading-[1.12] text-ink">
        {item.zh}
      </h1>
      <p class="text-[17px] text-muted">{item.en}</p>
    </div>
  </section>

  {/* 主體：流程步驟（左）／原理說明＋快速示意（右）＋ 注意事項（下）。videosOnly / termsOnly 分類不顯示 */}
  {!videosOnly && !termsOnly && (
  <article class="mx-auto max-w-[1180px] px-8 pb-16 pt-10">
    <div class="grid gap-x-12 gap-y-10 md:grid-cols-[1.6fr_1fr]">
      {/* 左：流程步驟 */}
      <div class="prose-custom">
        <h2>{content?.methodsTitle ?? "流程步驟"}</h2>
        {content?.methods ? (
          <div class="method-tabs">
            <div role="tablist" class="mb-5 flex flex-wrap gap-2">
              {content.methods.map((m, i) => (
                <button
                  type="button"
                  role="tab"
                  data-tab={i}
                  class="method-tab cursor-pointer rounded-full border border-border-strong bg-surface px-4 py-1.5 text-sm font-medium transition-colors hover:border-brand"
                >
                  {m.tab}
                </button>
              ))}
            </div>
            {content.methods.map((m, i) => (
              <div class="method-panel" data-panel={i} data-video={m.video ?? ""} data-image={m.image ?? ""} data-principle={m.principle ?? ""} hidden={i !== 0}>
                {m.name ? (
                  <div class="mb-3 text-[15px] font-medium text-ink">{m.name}</div>
                ) : m.tags && m.tags.length > 0 ? (
                  <div class="mb-3 flex flex-wrap items-center gap-2">
                    <span class="text-[13px] text-ink">適合</span>
                    {m.tags.map((tag) => (
                      <span class="inline-block rounded-md bg-surface px-3 py-1 text-[13px] text-muted shadow-[0_0_0_1px_var(--border-strong)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                ) : null}
                {m.sections ? (
                  m.sections.map((sec) => (
                    <div class="method-section">
                      <div class="method-section-title">
                        {parseAccent(sec.title).map((seg) =>
                          seg.accent ? <span class="accent-strong">{seg.text}</span> : seg.text
                        )}
                      </div>
                      <ol>
                        {sec.steps.map((s) => {
                          const { text, sub } = stepParts(s);
                          return (
                            <li>
                              {parseAccent(text).map((seg) =>
                                seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                              )}
                              {sub.length > 0 && (
                                <ul class="step-sub">
                                  {sub.map((d) => (
                                    <li class={/^[（(]/.test(d) ? "step-sub-deep" : ""}>
                                      {parseAccent(d).map((seg) =>
                                        seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                                      )}
                                    </li>
                                  ))}
                                </ul>
                              )}
                            </li>
                          );
                        })}
                      </ol>
                    </div>
                  ))
                ) : m.bullets ? (
                  <ul>
                    {m.bullets.map((b) => (
                      <li>
                        {parseAccent(b.replace(/^・\s*/, "")).map((seg) =>
                          seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                        )}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <ol>
                    {(m.steps ?? []).map((s) => {
                      const { text, sub } = stepParts(s);
                      return (
                        <li>
                          {parseAccent(text).map((seg) =>
                            seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                          )}
                          {sub.length > 0 && (
                            <ul class="step-sub">
                              {sub.map((d) => (
                                <li class={/^[（(]/.test(d) ? "step-sub-deep" : ""}>
                                  {parseAccent(d).map((seg) =>
                                    seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                                  )}
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      );
                    })}
                  </ol>
                )}
                {m.note && (
                  Array.isArray(m.note) ? (
                    <div class="mt-4 space-y-1">
                      {m.note.map((n) => (
                        <p class="text-[13px] leading-[1.7] text-muted">{n}</p>
                      ))}
                    </div>
                  ) : (
                    <p class="mt-4 text-[13px] leading-[1.7] text-muted">{m.note}</p>
                  )
                )}
              </div>
            ))}
          </div>
        ) : (
          <>
            <p class="note">⚠️ 步驟待補——Yuda 會陸續整理更新。</p>
            <ol>
              <li>（步驟一）</li>
              <li>（步驟二）</li>
              <li>（步驟三）</li>
            </ol>
          </>
        )}
      </div>

      {/* 右：B 原理說明 + C 快速示意 */}
      <div class="flex flex-col gap-8">
        {/* B: 原理說明 */}
        <div class="prose-custom">
          <h2>{content?.principleTitle ?? "原理說明"}</h2>
          {content?.principleItems ? (
            <ul>
              {content.principleItems.map((item) => (
                <li class={/^[①②③④⑤⑥⑦⑧⑨⑩]/.test(item) ? "principle-sub" : ""}>
                  {parseAccent(item).map((seg) => seg.accent ? <span class="text-accent">{seg.text}</span> : seg.text)}
                </li>
              ))}
            </ul>
          ) : hasDynamicPrinciple ? (
            <p id="principle-text">{content?.methods?.[0]?.principle ?? ""}</p>
          ) : (
            <p>
              {content?.principle ? (
                parseName(content.principle).map((seg) =>
                  seg.name ? <u style="text-decoration-color: white; text-underline-offset: 3px;">{seg.text}</u> : seg.text
                )
              ) : (
                `本系列說明「${item.zh}」的基本概念與適用範圍。操作前請確認遊戲版本，部分技巧僅限特定版本可用。`
              )}
            </p>
          )}
          {content?.principleNote && (
            <p class="mt-3 text-[13px] leading-[1.7] text-muted">{content.principleNote}</p>
          )}
        </div>

        {/* C: 快速示意（影片或圖片，隨分頁切換） */}
        {hasMedia && (
          <div class="prose-custom">
            <h2>快速示意</h2>
            <div
              id="demo-media-wrap"
              data-video-base={videoBase}
              data-image-base={imageBase}
              class="relative overflow-hidden rounded-xl bg-sand"
            >
              <video
                id="demo-video"
                controls
                loop
                muted
                playsinline
                class="hidden w-full rounded-xl"
              ></video>
              <a id="demo-image-link" href="#" target="_blank" rel="noopener" class="hidden">
                <img
                  id="demo-image"
                  alt="快速示意圖"
                  loading="lazy"
                  class="w-full rounded-xl"
                />
              </a>
              <div
                id="demo-media-empty"
                class="hidden flex-col items-center justify-center py-10 text-center text-[14px] text-muted"
              >
                <span>示意內容準備中</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>

    {/* 注意事項：跨兩欄 */}
    <div class="prose-custom mt-10 border-t border-border-soft pt-10">
      <h2>{content?.notesTitle ?? "注意事項"}</h2>
      <ul>
        {content?.notes ? (
          content.notes.map((n) => (
            <li>
              {parseAccent(n.text).map((seg) =>
                seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
              )}
              {n.sub && n.sub.length > 0 && (
                <ul class="note-sub">
                  {n.sub.map((s) => (
                    <li>
                      {parseAccent(s).map((seg) =>
                        seg.accent ? <span class="accent-text">{seg.text}</span> : seg.text
                      )}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        ) : (
          <>
            <li>本頁說明為示意內容，正式攻略步驟尚在整理中。</li>
            <li>如有疑問，歡迎前往 YouTube 頻道留言詢問。</li>
          </>
        )}
      </ul>
      {content?.closing && <p class="mt-1 text-[15px] text-muted">{content.closing}</p>}
      {content?.faqLink && (
        <div class="mt-6">
          <a
            href={href(content.faqLink.path)}
            class="faq-btn inline-flex items-center gap-2 no-underline"
          >
            {content.faqLink.label}
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" class="flex-none">
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      )}
    </div>
  </article>
  )}

  {/* termsOnly 頁的名詞說明 */}
  {termsOnly && (
    <div class="border-b border-border-soft">
      <div class="mx-auto max-w-[1180px] px-8 pb-12 pt-10">
        <h2 class="mb-8 font-serif text-[22px] font-medium text-ink">名詞說明</h2>
        {content?.termGroups && content.termGroups.length > 0 ? (
          content.termGroups.map((tg: TermGroup) => (
            <div class="mb-10 last:mb-0">
              <div class="mb-4 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">{tg.title}</div>
              <ul class="space-y-2.5 list-none p-0">
                {tg.terms.map((term) => (
                  <li class="flex gap-0 text-[15px] leading-[1.7]">
                    <span class="text-ink">{term.zh}</span>
                    {term.en && <span class="text-muted">&nbsp;/&nbsp;{term.en}</span>}
                  </li>
                ))}
              </ul>
            </div>
          ))
        ) : (
          <p class="text-[15px] text-muted">名詞說明整理中，敬請期待。</p>
        )}
      </div>
    </div>
  )}

  {/* videosOnly 頁的簡介與說明 */}
  {videosOnly && (
    <div class="border-b border-border-soft">
      <div class="mx-auto max-w-[1180px] px-8 pb-10 pt-10">
        <h2 class="mb-4 font-serif text-[22px] font-medium text-ink">簡介與說明</h2>
        {content?.intro ? (
          <p class="text-[16px] leading-[1.8] text-ink">{content.intro}</p>
        ) : (
          <p class="text-[15px] text-muted">說明內容整理中，敬請期待。</p>
        )}
      </div>
    </div>
  )}

  {/* 相關影片 */}
  {content?.videos && content.videos.length > 0 ? (
    <section class={vidSectionClass}>
      <div class="mx-auto max-w-[1180px] px-8 pb-16 pt-10">
        <div class="mb-6 flex items-end justify-between gap-5">
          <div>
            <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">
              相關影片 · Videos
            </div>
            <h2 class="mt-2 font-serif text-[26px] font-medium text-ink">
              {item.zh} 相關影片
            </h2>
          </div>
          {content.videos.length > VIDEOS_PER_PAGE && (
            <span id="vid-page-label" class="whitespace-nowrap text-[13px] text-muted"></span>
          )}
        </div>
        <div id="related-videos">
          {content.videos.map((v, i) => (
            <a
              href={ytWatch(v.id)}
              target="_blank"
              rel="noopener"
              data-vindex={i}
              class={`related-video flex cursor-pointer items-center gap-4 border-b border-border-soft py-[14px] no-underline transition-colors ${vidRowHover}`}
            >
              <img
                src={ytThumb(v.id)}
                alt={v.title}
                loading="lazy"
                class="h-[79px] w-[140px] flex-none rounded-lg bg-sand object-cover"
              />
              <div class="min-w-0 flex-1">
                <div class="line-clamp-2 font-serif text-[17px] font-medium leading-[1.3] text-ink">
                  {v.title}
                </div>
                <div class="mt-1 flex items-center gap-1.5 text-[13px] text-muted">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11">
                    <polygon points="6,4 20,12 6,20"></polygon>
                  </svg>
                  {v.desc || "YouTube"}
                </div>
              </div>
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" class="flex-none text-muted">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          ))}
        </div>

        {content.videos.length > VIDEOS_PER_PAGE && (
          <div class="mt-8 flex items-center justify-between gap-4">
            <button
              id="vid-prev"
              type="button"
              class={`rounded-[10px] border border-border-strong ${vidBtnBg} px-5 py-2 text-[15px] font-medium text-ink transition-colors hover:border-brand hover:text-brand disabled:cursor-not-allowed disabled:opacity-40`}
            >
              ← 上一頁
            </button>
            <span id="vid-page-info" class="text-sm text-muted"></span>
            <button
              id="vid-next"
              type="button"
              class={`rounded-[10px] border border-border-strong ${vidBtnBg} px-5 py-2 text-[15px] font-medium text-ink transition-colors hover:border-brand hover:text-brand disabled:cursor-not-allowed disabled:opacity-40`}
            >
              下一頁 →
            </button>
          </div>
        )}
      </div>
    </section>
  ) : (
    <section class={vidSectionClass}>
      <div class="mx-auto max-w-[1180px] px-8 py-12">
        <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">相關影片 · Videos</div>
        <p class="mt-3 text-[15px] text-muted">影片整理中，敬請期待。</p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .prose-custom {
    color: var(--text);
    line-height: 1.75;
    font-size: 16px;
  }
  .prose-custom h2 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    margin-top: 0;
    margin-bottom: 0.7em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid var(--border-soft);
  }
  .prose-custom p,
  .prose-custom ul,
  .prose-custom ol {
    margin-bottom: 1.1em;
  }
  .prose-custom ul,
  .prose-custom ol {
    padding-left: 1.6em;
  }
  .prose-custom ol {
    list-style: decimal;
  }
  .prose-custom ul {
    list-style: disc;
  }
  .prose-custom li::marker {
    color: var(--accent);
  }

  /* 步驟中的橙色文字 */
  .accent-text {
    color: var(--accent);
    font-weight: 500;
  }

  /* 注意事項的子清單 */
  .prose-custom .note-sub {
    list-style: none;
    padding-left: 1em;
    margin-top: 0.5em;
    margin-bottom: 0;
  }
  .prose-custom .note-sub li {
    margin-bottom: 0.3em;
    color: var(--muted);
    font-size: 15px;
  }
  .prose-custom .note-sub li::marker {
    content: none;
  }

  /* 步驟內的巢狀子項目（・、(1)(2) 開頭） */
  .prose-custom .step-sub {
    list-style: none;
    padding-left: 0;
    margin-top: 0.5em;
    margin-bottom: 0;
  }
  .prose-custom .step-sub li {
    margin-bottom: 0.35em;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.7;
  }
  .prose-custom .step-sub li::marker {
    content: none;
  }
  .prose-custom .step-sub .step-sub-deep {
    padding-left: 1.2em;
  }

  /* 原理說明的次層條列（①②③ 開頭） */
  .prose-custom .principle-sub {
    list-style: none;
    padding-left: 0.8em;
    margin-bottom: 0.25em;
  }

  /* 原理說明中的人名白色底線 */
  .name-underline {
    text-decoration: underline 2px white;
    text-underline-offset: 3px;
  }
  .prose-custom li {
    margin-bottom: 0.5em;
  }
  .prose-custom ol li {
    padding-left: 0.2em;
  }
  .prose-custom u {
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .prose-custom .note {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 14px;
    color: var(--muted);
  }

  /* 多區塊步驟的子標題 */
  .method-section + .method-section {
    margin-top: 1.6em;
    padding-top: 1.4em;
    border-top: 1px solid var(--border-soft);
  }
  .method-section-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-bottom: 0.75em;
    text-transform: uppercase;
  }
  /* 區塊標題內的重點：以底線強調（標題本身已是橙色） */
  .method-section-title .accent-strong {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Q&A 按鈕 */
  .faq-btn {
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--ink);
    border-radius: 10px;
    padding: 10px 20px;
    font-size: 15px;
    font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
  }
  .faq-btn:hover {
    border-color: var(--brand);
    color: var(--brand);
  }

  /* 分頁字色：未選為一般文字色，選中為象牙白（兩個主題皆清晰） */
  .method-tab {
    color: var(--text);
  }
  .method-tab[aria-selected="true"] {
    background: var(--brand);
    border-color: var(--brand);
    color: #faf9f5;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".method-tabs").forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>(".method-tab"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>(".method-panel"));

    const mediaWrap = document.getElementById("demo-media-wrap");
    const videoEl = document.getElementById("demo-video") as HTMLVideoElement | null;
    const imageLink = document.getElementById("demo-image-link") as HTMLAnchorElement | null;
    const imageEl = document.getElementById("demo-image") as HTMLImageElement | null;
    const mediaEmpty = document.getElementById("demo-media-empty");
    const videoBase = mediaWrap?.dataset.videoBase ?? "";
    const imageBase = mediaWrap?.dataset.imageBase ?? "";

    function showOnly(which: "video" | "image" | "empty") {
      videoEl?.classList.toggle("hidden", which !== "video");
      imageLink?.classList.toggle("hidden", which !== "image");
      if (mediaEmpty) {
        mediaEmpty.classList.toggle("hidden", which !== "empty");
        mediaEmpty.classList.toggle("flex", which === "empty");
      }
    }

    function updateMedia(index: number) {
      if (!mediaWrap) return;
      const panel = panels[index];
      const image = panel?.dataset.image ?? "";
      const video = panel?.dataset.video ?? "";

      if (image && imageEl && imageLink) {
        const src = `${imageBase}/${image}`;
        if (imageEl.getAttribute("src") !== src) imageEl.src = src;
        imageLink.href = src;
        videoEl?.pause();
        showOnly("image");
      } else if (video && videoEl) {
        const src = `${videoBase}/${video}`;
        if (videoEl.getAttribute("src") !== src) {
          videoEl.pause();
          videoEl.src = src;
          videoEl.load();
        }
        showOnly("video");
      } else {
        videoEl?.pause();
        showOnly("empty");
      }
    }

    const principleText = document.getElementById("principle-text");

    function select(index: number) {
      tabs.forEach((t, i) => t.setAttribute("aria-selected", String(i === index)));
      panels.forEach((p, i) => (p.hidden = i !== index));
      updateMedia(index);
      if (principleText) {
        principleText.textContent = panels[index]?.dataset.principle ?? "";
      }
    }

    tabs.forEach((tab, i) => tab.addEventListener("click", () => select(i)));
    select(0);
  });

  // 相關影片分頁（每頁 10 部）
  (function () {
    const PER_PAGE = 10;
    const rows = Array.from(document.querySelectorAll<HTMLElement>(".related-video"));
    if (rows.length <= PER_PAGE) return;

    const prevBtn = document.getElementById("vid-prev") as HTMLButtonElement | null;
    const nextBtn = document.getElementById("vid-next") as HTMLButtonElement | null;
    const pageInfo = document.getElementById("vid-page-info");
    const pageLabel = document.getElementById("vid-page-label");
    const totalPages = Math.ceil(rows.length / PER_PAGE);
    let page = 1;

    function render() {
      const start = (page - 1) * PER_PAGE;
      const end = start + PER_PAGE;
      rows.forEach((r, i) => (r.style.display = i >= start && i < end ? "" : "none"));
      if (prevBtn) prevBtn.disabled = page === 1;
      if (nextBtn) nextBtn.disabled = page === totalPages;
      const label = `第 ${page} 頁，共 ${totalPages} 頁`;
      if (pageInfo) pageInfo.textContent = label;
      if (pageLabel) pageLabel.textContent = label;
    }

    prevBtn?.addEventListener("click", () => {
      if (page > 1) { page--; render(); }
    });
    nextBtn?.addEventListener("click", () => {
      if (page < totalPages) { page++; render(); }
    });

    render();
  })();
</script>
