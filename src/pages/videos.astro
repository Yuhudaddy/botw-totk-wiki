---
import BaseLayout from "../layouts/BaseLayout.astro";
import youtubeData from "../data/youtube.json";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

const GAME_LABELS: Record<string, string> = {
  botw: "曠野之息",
  totk: "王國之淚",
  eow: "智慧的再現",
};

// CI 跑過 fetch-youtube.mjs 後會有 all[]；本地 seed 沒有時 fallback 合併三個遊戲陣列
const rawAll: any[] = (youtubeData as any).all ?? [
  ...((youtubeData as any).botw ?? []).map((v: any) => ({ ...v, game: "botw" })),
  ...((youtubeData as any).totk ?? []).map((v: any) => ({ ...v, game: "totk" })),
  ...((youtubeData as any).eow  ?? []).map((v: any) => ({ ...v, game: "eow"  })),
];
const videos = rawAll.map((v: any) => ({
  ytId: v.id,
  title: v.title,
  game: v.game ?? "",
  gameLabel: GAME_LABELS[v.game] ?? "",
  search: [v.title, v.meta ?? "", GAME_LABELS[v.game] ?? "", v.game ?? ""].join(" ").toLowerCase(),
}));

const facets = [
  { key: "botw", label: "曠野之息" },
  { key: "totk", label: "王國之淚" },
  { key: "eow", label: "智慧的再現" },
];
---

<BaseLayout title="影片索引" active="videos">
  <section class="mx-auto max-w-[1180px] px-8 pb-[84px] pt-12">
    <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">影片索引 · Video Index</div>
    <h1 class="mb-2.5 mt-3.5 font-serif text-[42px] font-medium text-ink">搜尋頻道內所有內容</h1>
    <p class="mb-7 max-w-[60ch] text-base leading-[1.6] text-text">
      輸入關鍵字搜尋教學頁與相關影片。多個關鍵字以空格分隔可疊加篩選，例如「偷襲 曠野」。
    </p>

    {/* 搜尋框 */}
    <div class="relative mb-[18px] max-w-[560px]">
      <span class="pointer-events-none absolute left-[15px] top-1/2 -translate-y-1/2 text-muted">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </span>
      <input
        id="idx-search"
        type="search"
        placeholder="搜尋教學或影片，例如「轉存格」「偷襲 曠野」…"
        class="w-full rounded-xl border border-border-strong bg-surface py-[13px] pl-11 pr-4 text-[15px] text-ink outline-none focus:border-brand"
      />
    </div>

    {/* 遊戲篩選 */}
    <div id="idx-facets" class="mb-9 flex flex-wrap gap-2.5">
      <button type="button" data-game="" class="chip rounded-full border border-border-strong px-[15px] py-[7px] text-sm">
        全部
      </button>
      {
        facets.map((f) => (
          <button type="button" data-game={f.key} class="chip rounded-full border border-border-strong px-[15px] py-[7px] text-sm">
            {f.label}
          </button>
        ))
      }
    </div>

    {/* 結果區（由 JS 渲染） */}
    <div id="idx-results"></div>

    {/* 空狀態 */}
    <div id="idx-empty" class="hidden py-[60px] text-center text-muted">
      <p class="mb-2 font-serif text-[22px] text-ink">找不到符合的內容</p>
      <p class="text-[15px]">換個關鍵字，或清除篩選試試。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .chip {
    cursor: pointer;
    background: var(--surface);
    color: var(--text);
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .chip[data-active="true"] {
    background: var(--brand);
    color: #faf9f5;
    border-color: var(--brand);
  }

  /* ── 以下為動態注入 HTML 的樣式，須用 :global() 繞過 Astro scoping ── */
  :global(.idx-bucket-title) {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 500;
    margin: 8px 0 4px;
  }
  :global(.idx-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 6px;
    border-bottom: 1px solid var(--border-soft);
    text-decoration: none;
    transition: background-color 0.12s;
    min-height: 44px;
  }
  :global(.idx-row:hover) {
    background: var(--surface);
    border-radius: 6px;
  }
  :global(.idx-tag) {
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 8px;
    background: var(--surface);
    color: var(--muted);
    white-space: nowrap;
    box-shadow: 0 0 0 1px var(--border-strong);
    flex: none;
  }
  :global(.idx-hl) {
    color: var(--accent);
    font-weight: 500;
  }
  :global(.idx-grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    padding: 4px 0;
  }
  :global(.idx-grid-card) {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  :global(.idx-grid-card:hover) {
    border-color: var(--brand);
    box-shadow: 0 2px 12px var(--shadow);
  }
  :global(.idx-grid-card img) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--sand);
    display: block;
  }
  :global(.idx-grid-card-body) {
    padding: 10px 12px 12px;
    flex: 1;
  }
  :global(.view-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  :global(.view-btn[data-active="true"]) {
    background: var(--brand);
    color: #faf9f5;
    border-color: var(--brand);
  }
  :global(.view-btn:hover:not([data-active="true"])) {
    background: var(--surface-2);
    color: var(--ink);
  }
  :global(.page-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 34px;
    padding: 0 6px;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
    transition: background-color 0.12s, color 0.12s, border-color 0.12s;
  }
  :global(.page-btn[data-active="true"]) {
    background: var(--brand);
    color: #faf9f5;
    border-color: var(--brand);
  }
  :global(.page-btn:hover:not([data-active="true"]):not(:disabled)) {
    background: var(--surface-2);
    color: var(--ink);
  }
  :global(.page-btn:disabled) {
    opacity: 0.35;
    cursor: default;
  }
  @media (max-width: 768px) {
    :global(.idx-grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    :global(.idx-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ videos, facets, BASE }}>
  (function () {
    var search = document.getElementById("idx-search");
    var facetBox = document.getElementById("idx-facets");
    var results = document.getElementById("idx-results");
    var empty = document.getElementById("idx-empty");
    var chips = Array.prototype.slice.call(document.querySelectorAll(".chip"));

    var game = "";
    var terms = [];
    var viewMode = "list"; // "list" | "grid"
    var videoPage = 0;
    var VIDEOS_PER_LIST = 10;
    var VIDEOS_PER_GRID = 40;

    /* ── 工具函式 ── */
    function esc(s) {
      return String(s).replace(/[&<>]/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c];
      });
    }
    function escRe(s) {
      return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }
    function hl(text) {
      var out = esc(text);
      for (var i = 0; i < terms.length; i++) {
        if (!terms[i]) continue;
        out = out.replace(new RegExp(escRe(terms[i]), "gi"), function (m) {
          return '<span class="idx-hl">' + m + "</span>";
        });
      }
      return out;
    }
    function matchAll(hay) {
      for (var i = 0; i < terms.length; i++) {
        if (terms[i] && hay.indexOf(terms[i]) < 0) return false;
      }
      return true;
    }
    function inGame(g) {
      return !game || g === game;
    }
    function ytThumb(id) {
      return "https://img.youtube.com/vi/" + id + "/hqdefault.jpg";
    }

    /* ── 影片列（純文字，無縮圖） ── */
    function videoListRow(v) {
      return (
        '<a class="idx-row" href="https://youtu.be/' + v.ytId + '" target="_blank" rel="noopener">' +
        '<svg style="flex:none;color:var(--accent);" viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>' +
        '<div style="flex:1; min-width:0;">' +
        '<div style="font-size:14px; line-height:1.4; color:var(--ink);" class="font-serif">' + hl(v.title) + "</div>" +
        (v.gameLabel ? '<div style="font-size:12px; color:var(--muted); margin-top:2px;">' + esc(v.gameLabel) + "</div>" : "") +
        "</div>" +
        "</a>"
      );
    }

    /* ── 影片格狀卡 ── */
    function videoGridCard(v) {
      return (
        '<a class="idx-grid-card" href="https://youtu.be/' + v.ytId + '" target="_blank" rel="noopener">' +
        '<img loading="lazy" alt="" src="' + ytThumb(v.ytId) + '" />' +
        '<div class="idx-grid-card-body">' +
        '<div style="font-size:13px; line-height:1.4; color:var(--ink); display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;" class="font-serif">' + hl(v.title) + "</div>" +
        (v.gameLabel ? '<div style="font-size:11px; color:var(--muted); margin-top:5px;">' + esc(v.gameLabel) + "</div>" : "") +
        "</div>" +
        "</a>"
      );
    }

    /* ── 分頁列 ── */
    function paginationHTML(current, total) {
      var html = '<div style="display:flex;align-items:center;justify-content:center;gap:5px;margin-top:22px;padding-bottom:4px;">';

      // 上一頁
      html += '<button class="page-btn" data-page="' + (current - 1) + '"' + (current === 0 ? " disabled" : "") + ">←</button>";

      // 頁碼（最多顯示 7 個，超出用 …）
      var start = Math.max(0, current - 3);
      var end = Math.min(total - 1, start + 6);
      if (end - start < 6) start = Math.max(0, end - 6);

      if (start > 0) {
        html += '<button class="page-btn" data-page="0">1</button>';
        if (start > 1) html += '<span style="color:var(--muted);font-size:13px;padding:0 2px;">…</span>';
      }
      for (var i = start; i <= end; i++) {
        html += '<button class="page-btn" data-page="' + i + '" data-active="' + (i === current ? "true" : "false") + '">' + (i + 1) + "</button>";
      }
      if (end < total - 1) {
        if (end < total - 2) html += '<span style="color:var(--muted);font-size:13px;padding:0 2px;">…</span>';
        html += '<button class="page-btn" data-page="' + (total - 1) + '">' + total + "</button>";
      }

      // 下一頁
      html += '<button class="page-btn" data-page="' + (current + 1) + '"' + (current === total - 1 ? " disabled" : "") + ">→</button>";
      html += "</div>";
      return html;
    }

    /* ── 切換按鈕 HTML ── */
    function viewToggleHTML() {
      return (
        '<div style="display:flex;gap:5px;">' +
        '<button class="view-btn" data-view="list" data-active="' + (viewMode === "list" ? "true" : "false") + '" title="列表">' +
        '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>' +
        "</button>" +
        '<button class="view-btn" data-view="grid" data-active="' + (viewMode === "grid" ? "true" : "false") + '" title="格狀">' +
        '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect></svg>' +
        "</button>" +
        "</div>"
      );
    }

    /* ── 主要渲染 ── */
    function render() {
      var hasSearch = terms.length > 0;
      var html = "";

      var totalVideos = videos.filter(function (v) { return inGame(v.game); }).length;
      var mv = hasSearch
        ? videos.filter(function (v) { return inGame(v.game) && matchAll(v.search); })
        : [];

      /* 預設狀態：僅顯示統計提示 */
      if (!hasSearch) {
        html += '<div style="font-size:13px;color:var(--muted);margin-bottom:10px;">共 ' + totalVideos + ' 支影片，輸入關鍵字開始搜尋。</div>';
      }

      /* 搜尋結果：影片 */
      if (hasSearch && mv.length > 0) {
        var perPage = viewMode === "list" ? VIDEOS_PER_LIST : VIDEOS_PER_GRID;
        var totalPages = Math.ceil(mv.length / perPage);
        if (videoPage >= totalPages) videoPage = 0;
        var pageVideos = mv.slice(videoPage * perPage, (videoPage + 1) * perPage);

        /* 標題列 + 切換按鈕 */
        html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">';
        html +=
          '<div class="idx-bucket-title" style="margin:0;color:var(--muted);">' +
          '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>' +
          "影片（" + mv.length + "）</div>";
        html += viewToggleHTML();
        html += "</div>";

        if (viewMode === "list") {
          for (var j = 0; j < pageVideos.length; j++) html += videoListRow(pageVideos[j]);
        } else {
          html += '<div class="idx-grid">';
          for (var k = 0; k < pageVideos.length; k++) html += videoGridCard(pageVideos[k]);
          html += "</div>";
        }

        if (totalPages > 1) html += paginationHTML(videoPage, totalPages);
      }

      results.innerHTML = html;

      /* 動態按鈕事件 */
      results.querySelectorAll(".view-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          viewMode = this.getAttribute("data-view");
          videoPage = 0;
          render();
        });
      });
      results.querySelectorAll(".page-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          if (this.disabled) return;
          videoPage = parseInt(this.getAttribute("data-page"), 10);
          render();
          results.scrollIntoView({ behavior: "smooth", block: "nearest" });
        });
      });

      /* 空狀態：有搜尋但無結果 */
      var showEmpty = hasSearch && mv.length === 0;
      if (empty) empty.classList.toggle("hidden", !showEmpty);
    }

    /* ── Chip active 狀態 ── */
    function setActiveChip() {
      chips.forEach(function (c) {
        c.setAttribute("data-active", c.getAttribute("data-game") === game ? "true" : "false");
      });
    }
    function setTerms(str) {
      terms = (str || "").toLowerCase().split(/\s+/).filter(Boolean);
      videoPage = 0;
    }

    /* ── 初始化：讀 URL ?search= / ?tag= / ?game= ── */
    try {
      var params = new URLSearchParams(window.location.search);
      var q = params.get("search") || params.get("tag") || "";
      var g = params.get("game") || "";
      if (g && facets.some(function (f) { return f.key === g; })) game = g;
      if (q) {
        setTerms(q);
        if (search) search.value = q;
      }
    } catch (e) {}

    setActiveChip();
    render();

    if (search) {
      search.addEventListener("input", function (e) {
        setTerms((e.target.value || "").trim());
        render();
      });
    }
    if (facetBox) {
      facetBox.addEventListener("click", function (e) {
        var btn = e.target.closest(".chip");
        if (!btn) return;
        game = btn.getAttribute("data-game") || "";
        videoPage = 0;
        setActiveChip();
        render();
      });
    }
  })();
</script>
