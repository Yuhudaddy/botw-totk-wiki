---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildVideoIndex } from "../lib/video-index";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const { guides, videos, facets } = buildVideoIndex();
---

<BaseLayout title="影片索引" active="videos">
  <section class="mx-auto max-w-[1180px] px-8 pb-[84px] pt-12">
    <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">影片索引 · Video Index</div>
    <h1 class="mb-2.5 mt-3.5 font-serif text-[42px] font-medium text-ink">搜尋頻道內所有內容</h1>
    <p class="mb-7 max-w-[60ch] text-base leading-[1.6] text-text">
      一次搜尋手寫教學與相關影片。輸入多個關鍵字（以空格分隔）可疊加篩選，例如「偷襲 曠野」。
    </p>

    {/* 搜尋框 */}
    <div class="relative mb-[18px] max-w-[560px]">
      <span class="pointer-events-none absolute left-[15px] top-1/2 -translate-y-1/2 text-muted">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </span>
      <input
        id="idx-search"
        type="search"
        placeholder="搜尋教學或影片，例如「轉存格」「偷襲 曠野」…"
        class="w-full rounded-xl border border-border-strong bg-surface py-[13px] pl-11 pr-4 text-[15px] text-ink outline-none focus:border-brand"
      />
    </div>

    {/* 遊戲篩選 */}
    <div id="idx-facets" class="mb-9 flex flex-wrap gap-2.5">
      <button type="button" data-game="" class="chip rounded-full border border-border-strong px-[15px] py-[7px] text-sm">
        全部
      </button>
      {
        facets.map((f) => (
          <button type="button" data-game={f.key} class="chip rounded-full border border-border-strong px-[15px] py-[7px] text-sm">
            {f.label}
          </button>
        ))
      }
    </div>

    {/* 結果區（由 JS 渲染） */}
    <div id="idx-results"></div>

    {/* 空狀態 */}
    <div id="idx-empty" class="hidden py-[60px] text-center text-muted">
      <p class="mb-2 font-serif text-[22px] text-ink">找不到符合的內容</p>
      <p class="text-[15px]">換個關鍵字，或清除篩選試試。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .chip {
    cursor: pointer;
    background: var(--surface);
    color: var(--text);
  }
  .chip[data-active="true"] {
    background: var(--brand);
    color: #faf9f5;
    border-color: var(--brand);
  }
  .idx-group-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    margin: 22px 0 4px;
  }
  .idx-bucket-title {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 500;
    margin: 8px 0 4px;
  }
  .idx-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--border-soft);
    text-decoration: none;
    transition: background-color 0.15s;
  }
  .idx-row:hover {
    background: var(--surface);
  }
  .idx-thumb {
    width: 140px;
    height: 79px;
    flex: none;
    border-radius: 8px;
    background: var(--sand);
    object-fit: cover;
  }
  .idx-thumb-guide {
    width: 140px;
    height: 79px;
    flex: none;
    border-radius: 8px;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    box-shadow: 0 0 0 1px var(--border-strong);
  }
  .idx-tag {
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 8px;
    background: var(--surface);
    color: var(--muted);
    white-space: nowrap;
    box-shadow: 0 0 0 1px var(--border-strong);
  }
  .idx-hl {
    color: var(--accent);
    font-weight: 500;
  }
</style>

<script define:vars={{ guides, videos, facets, BASE }}>
  (function () {
    var search = document.getElementById("idx-search");
    var facetBox = document.getElementById("idx-facets");
    var results = document.getElementById("idx-results");
    var empty = document.getElementById("idx-empty");
    var chips = Array.prototype.slice.call(document.querySelectorAll(".chip"));

    var game = "";
    var terms = [];

    function esc(s) {
      return String(s).replace(/[&<>]/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c];
      });
    }
    function escRe(s) {
      return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }
    function hl(text) {
      var out = esc(text);
      for (var i = 0; i < terms.length; i++) {
        if (!terms[i]) continue;
        out = out.replace(new RegExp(escRe(terms[i]), "gi"), function (m) {
          return '<span class="idx-hl">' + m + "</span>";
        });
      }
      return out;
    }
    function matchAll(hay) {
      for (var i = 0; i < terms.length; i++) {
        if (terms[i] && hay.indexOf(terms[i]) < 0) return false;
      }
      return true;
    }
    function inGame(g) {
      return !game || g === game;
    }
    function ytThumb(id) {
      return "https://img.youtube.com/vi/" + id + "/hqdefault.jpg";
    }

    function videoRow(v) {
      return (
        '<a class="idx-row" href="https://youtu.be/' + v.ytId + '" target="_blank" rel="noopener">' +
        '<img class="idx-thumb" loading="lazy" alt="" src="' + ytThumb(v.ytId) + '" />' +
        '<div style="flex:1; min-width:0;">' +
        '<div style="font-size:15px; line-height:1.4; color:var(--ink);" class="font-serif">' + hl(v.title) + "</div>" +
        '<div style="font-size:13px; color:var(--muted); margin-top:3px;">' + esc(v.gameLabel) + "</div>" +
        "</div>" +
        '<span class="idx-tag">' + esc(v.fromZh) + "</span>" +
        "</a>"
      );
    }
    function guideRow(g) {
      return (
        '<a class="idx-row" href="' + BASE + "/types/" + g.id + '">' +
        '<div class="idx-thumb-guide">' +
        '<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 5a2 2 0 0 1 2-2h12a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H6a2 2 0 0 1-2-2z"></path><line x1="8" y1="7" x2="15" y2="7"></line><line x1="8" y1="11" x2="15" y2="11"></line></svg>' +
        "</div>" +
        '<div style="flex:1; min-width:0;">' +
        '<div style="font-size:15px; font-weight:500; color:var(--ink);" class="font-serif">' + hl(g.zh) +
        ' <span style="font-weight:400; color:var(--muted); font-size:13px;">' + hl(g.en) + "</span></div>" +
        '<div style="font-size:13px; color:var(--muted); margin-top:3px;">' + esc(g.gameLabel) + " · 教學頁</div>" +
        "</div>" +
        '<span class="idx-tag" style="color:var(--accent);">教學</span>' +
        "</a>"
      );
    }

    function render() {
      var html = "";
      var anyShown = false;

      if (terms.length === 0) {
        var vs = videos.filter(function (v) { return inGame(v.game); });
        var gs = guides.filter(function (g) { return inGame(g.game); });
        html += '<div style="font-size:13px; color:var(--text); margin-bottom:6px;">共 ' + gs.length + " 篇教學 · " + vs.length + " 支影片</div>";
        for (var i = 0; i < facets.length; i++) {
          var gk = facets[i].key;
          if (game && game !== gk) continue;
          var rows = vs.filter(function (v) { return v.game === gk; });
          if (!rows.length) continue;
          html += '<div class="idx-group-title">' + esc(facets[i].label) + "</div>";
          for (var j = 0; j < rows.length; j++) html += videoRow(rows[j]);
          anyShown = true;
        }
      } else {
        var mg = guides.filter(function (g) { return inGame(g.game) && matchAll(g.search); });
        var mv = videos.filter(function (v) { return inGame(v.game) && matchAll(v.search); });
        if (mg.length) {
          html +=
            '<div class="idx-bucket-title" style="color:var(--accent);">' +
            '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5a2 2 0 0 1 2-2h12a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H6a2 2 0 0 1-2-2z"></path></svg>' +
            "教學頁（" + mg.length + "）</div>";
          for (var k = 0; k < mg.length; k++) html += guideRow(mg[k]);
          anyShown = true;
        }
        if (mv.length) {
          html +=
            '<div class="idx-bucket-title" style="color:var(--muted); margin-top:18px;">' +
            '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>' +
            "影片（" + mv.length + "）</div>";
          for (var m = 0; m < mv.length; m++) html += videoRow(mv[m]);
          anyShown = true;
        }
      }

      results.innerHTML = html;
      if (empty) empty.classList.toggle("hidden", anyShown);
    }

    function setActiveChip() {
      chips.forEach(function (c) {
        c.setAttribute("data-active", c.getAttribute("data-game") === game ? "true" : "false");
      });
    }
    function setTerms(str) {
      terms = (str || "").toLowerCase().split(/\s+/).filter(Boolean);
    }

    // 初始化：讀 URL 的 ?search= / ?tag= / ?game=
    try {
      var params = new URLSearchParams(window.location.search);
      var q = params.get("search") || params.get("tag") || "";
      var g = params.get("game") || "";
      if (g && facets.some(function (f) { return f.key === g; })) game = g;
      if (q) {
        setTerms(q);
        if (search) search.value = q;
      }
    } catch (e) {}

    setActiveChip();
    render();

    if (search) {
      search.addEventListener("input", function (e) {
        setTerms((e.target.value || "").trim());
        render();
      });
    }
    if (facetBox) {
      facetBox.addEventListener("click", function (e) {
        var btn = e.target.closest(".chip");
        if (!btn) return;
        game = btn.getAttribute("data-game") || "";
        setActiveChip();
        render();
      });
    }
  })();
</script>
