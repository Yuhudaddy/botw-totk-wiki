---
import BaseLayout from "../layouts/BaseLayout.astro";
import { href } from "../lib/url";
import { typeGroups } from "../data/types";
---

<BaseLayout
  title="主題解說"
  description="依系列瀏覽 Yuda 頻道的曠野之息與王國之淚攻略內容。"
  active="types"
>
  {/* 標題 */}
  <section class="border-b border-border-soft">
    <div class="r-types-hero mx-auto max-w-[1180px] px-8 pb-12 pt-[54px]">
      <div class="mb-[22px] flex items-center gap-2.5 text-[13px] text-muted">
        <a href={href("/")} class="no-underline text-muted">首頁</a>
        <span>/</span>
        <span class="text-ink">主題解說</span>
      </div>
      <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">
        Browse by Series · 系列索引
      </div>
      <h1 class="r-types-h1 mb-[18px] mt-3.5 font-serif text-[46px] font-medium leading-[1.14] text-ink">
        主題解說
      </h1>
      <p class="max-w-[62ch] text-lg leading-[1.65] text-text">
        依系列瀏覽頻道內容——從風彈、轉存格到神廟特解與主線任務。各系列陸續補上對應的步驟說明與影片。
      </p>
    </div>
  </section>

  {/* 兩個遊戲分組 */}
  {
    typeGroups.map((group) => (
      <section class="mx-auto max-w-[1180px] px-8 pb-4 pt-[52px] last:pb-20">
        <div class="mb-[22px] flex items-end justify-between gap-5">
          <div>
            <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">
              {group.en}
            </div>
            <h2 class="mt-2.5 font-serif text-[30px] font-medium text-ink">{group.label}</h2>
          </div>
          <a
            href={href(`/videos?game=${group.game}`)}
            class="whitespace-nowrap text-sm text-accent no-underline"
          >
            全部影片 →
          </a>
        </div>

        <div class="r-type-grid grid grid-cols-[repeat(auto-fill,minmax(248px,1fr))] gap-[18px]">
          {group.items.map((item) => (
            <a
              href={href(`/types/${group.game}-${item.no}`)}
              class="group flex min-w-0 flex-col rounded-2xl border border-border-soft bg-surface px-4 py-3.5 no-underline transition-colors hover:border-brand"
            >
              <div class="flex min-w-0 items-baseline gap-2">
                <span class="flex-none font-mono text-[13px] text-accent">{item.no}</span>
                <span class="truncate font-serif text-[18px] font-medium text-ink">{item.zh}</span>
              </div>
              <div class="truncate text-[12px] text-muted">{item.en}</div>
            </a>
          ))}
        </div>
      </section>
    ))
  }

<style>
  @media (max-width: 600px) {
    .r-types-hero {
      padding-top: 28px;
      padding-bottom: 24px;
    }
    .r-types-h1 {
      font-size: 32px;
    }
    .r-type-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
  }
</style>
</BaseLayout>
