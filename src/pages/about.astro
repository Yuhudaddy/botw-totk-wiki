---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout title="關於 Yuda" active="about">
  <section class="mx-auto max-w-[820px] px-8 pb-[84px] pt-12">
    <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">關於 · About</div>
    <h1 class="mb-6 mt-3.5 font-serif text-[42px] font-medium text-ink">關於 Yuda</h1>

    {/* 簡介 */}
    <div class="rounded-2xl border border-border-strong bg-surface px-[30px] py-7">
      <p class="whitespace-pre-line text-base leading-[1.9] text-text">曾為日本社畜，玩遊戲玩到研究遊戲的玩家。
2023/11/30 小孩（Yukito）出生，
影片更新速度降低請見諒。</p>
    </div>

    {/* 連結 */}
    <div class="mt-8">
      <div class="mb-3 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">連結 · Links</div>
      <div class="flex flex-wrap gap-3">
        <a
          href={SITE.youtube}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[10px] border border-border-strong bg-surface-2 px-[18px] py-2.5 text-[15px] font-medium text-ink no-underline transition-colors hover:border-brand hover:text-brand"
        >
          YouTube 頻道 →
        </a>
        <a
          href={SITE.discord}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[10px] border border-border-strong bg-surface-2 px-[18px] py-2.5 text-[15px] font-medium text-ink no-underline transition-colors hover:border-brand hover:text-brand"
        >
          Discord 社群 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
