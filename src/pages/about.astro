---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout title="關於 Yuda" active="about">
  <section class="mx-auto max-w-[820px] px-8 pb-[84px] pt-12">
    <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">關於 · About</div>
    <h1 class="mb-6 mt-3.5 font-serif text-[42px] font-medium text-ink">關於 Yuda</h1>

    {/* 簡介 */}
    <div class="rounded-2xl border border-border-strong bg-surface px-[30px] py-7">
      <p class="text-base leading-[1.9] text-text">
        曾為日本社畜，玩遊戲玩到研究遊戲的玩家。<br />
        2023/11/30 小孩（Yukito）出生，影片更新速度降低請見諒。
      </p>
    </div>

    {/* 主要遊玩 */}
    <div class="mt-5 rounded-2xl border border-border-strong bg-surface px-[30px] py-7">
      <div class="mb-3 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">主要遊玩 · Main Games</div>
      <ol class="space-y-1.5 text-[15px] leading-[1.8] text-text">
        <li>① 薩爾達傳說（曠野以後的新作）</li>
        <li>② 寶可夢</li>
        <li>③ 無雙遊戲</li>
        <li>④ 洛克人X系列</li>
        <li>⑤ 瑪利歐系列</li>
        <li>⑥ 時空幻境</li>
        <li>⑦ 自己愛的懷舊遊戲</li>
      </ol>
    </div>

    {/* 語言 */}
    <div class="mt-5 rounded-2xl border border-border-strong bg-surface px-[30px] py-7">
      <div class="mb-3 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">語言 · Languages</div>
      <ul class="space-y-1.5 text-[15px] leading-[1.8] text-text">
        <li>・ 主要語言為中文（繁體中文／簡體中文），粵語不太會。</li>
        <li>・ Speak English（I always discuss glitches with English-speakers）</li>
        <li>・ 日本語可（在日でしたので。）</li>
      </ul>
    </div>

    {/* 關於 Yuhu */}
    <div class="mt-5 rounded-2xl border border-border-strong bg-surface px-[30px] py-7">
      <div class="mb-3 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">關於 Yuhu</div>
      <p class="text-[15px] leading-[1.8] text-text">
        大頭貼的黃金長毛臘腸狗是 Yuhu。<br />
        她的生日在《曠野之息》影片的
        <a
          href="https://www.youtube.com/watch?v=sa90NVj6AYQ"
          target="_blank"
          rel="noopener"
          class="text-brand underline underline-offset-2 hover:opacity-80"
        >番外11(新)</a>。
      </p>
    </div>

    {/* 連結 */}
    <div class="mt-8">
      <div class="mb-4 text-[11px] font-bold uppercase tracking-[1.4px] text-accent">連結 · Links</div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">

        {/* YouTube */}
        <a href={SITE.youtube} target="_blank" rel="noopener"
           class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border-strong bg-surface px-4 py-3.5 no-underline transition-all duration-200 hover:border-[#FF0000]">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="flex-none text-muted transition-colors duration-200 group-hover:text-[#FF0000]">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <div class="min-w-0">
            <div class="text-[14px] font-medium leading-tight text-ink">YouTube</div>
            <div class="mt-0.5 text-[11px] text-muted">Yuda（@yuhudaddy）</div>
          </div>
        </a>

        {/* X (Twitter) */}
        <a href={SITE.x} target="_blank" rel="noopener"
           class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border-strong bg-surface px-4 py-3.5 no-underline transition-all duration-200 hover:border-brand">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="flex-none text-muted transition-colors duration-200 group-hover:text-brand">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
          </svg>
          <div class="min-w-0">
            <div class="text-[14px] font-medium leading-tight text-ink">X (Twitter)</div>
            <div class="mt-0.5 text-[11px] text-muted">@zb_yuhudaddy</div>
          </div>
        </a>

        {/* Instagram */}
        <a href={SITE.instagram} target="_blank" rel="noopener"
           class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border-strong bg-surface px-4 py-3.5 no-underline transition-all duration-200 hover:border-[#E4405F]">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="flex-none text-muted transition-colors duration-200 group-hover:text-[#E4405F]">
            <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12c0 3.259.014 3.668.072 4.948.058 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24c3.259 0 3.668-.014 4.948-.072 1.277-.058 2.148-.261 2.913-.558.788-.306 1.459-.717 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.948 0-3.259-.014-3.667-.072-4.947-.058-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <div class="min-w-0">
            <div class="text-[14px] font-medium leading-tight text-ink">Instagram</div>
            <div class="mt-0.5 text-[11px] text-muted">@yuda_chc</div>
          </div>
        </a>

        {/* Threads */}
        <a href={SITE.threads} target="_blank" rel="noopener"
           class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border-strong bg-surface px-4 py-3.5 no-underline transition-all duration-200 hover:border-brand">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="flex-none text-muted transition-colors duration-200 group-hover:text-brand">
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-3 7h-2V7h2v2zm-4 0H7V7h6v2zm4 4h-2v-2h2v2zm-4 0H7v-2h6v2z"/>
          </svg>
          <div class="min-w-0">
            <div class="text-[14px] font-medium leading-tight text-ink">Threads</div>
            <div class="mt-0.5 text-[11px] text-muted">@yuda_chc</div>
          </div>
        </a>

        {/* Discord */}
        <a href={SITE.discord} target="_blank" rel="noopener"
           class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border-strong bg-surface px-4 py-3.5 no-underline transition-all duration-200 hover:border-[#5865F2]">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="flex-none text-muted transition-colors duration-200 group-hover:text-[#5865F2]">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.102 18.08.117 18.1.14 18.115a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          <div class="min-w-0">
            <div class="text-[14px] font-medium leading-tight text-ink">Discord</div>
            <div class="mt-0.5 text-[11px] text-muted">Yuda's Switch 道場</div>
          </div>
        </a>


</div>
    </div>
  </section>
</BaseLayout>
