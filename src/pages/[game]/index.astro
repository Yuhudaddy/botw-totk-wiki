---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { href } from "../../lib/url";
import { gameCategories, type GameKey } from "../../data/categories";

export function getStaticPaths() {
  return (["botw", "totk"] as GameKey[]).map((game) => ({
    params: { game },
  }));
}

const { game } = Astro.params as { game: GameKey };
const cat = gameCategories[game];
---

<BaseLayout title={cat.game} active={game}>
  {/* 麵包屑 + 標題 */}
  <section class="border-b border-border-soft">
    <div class="mx-auto max-w-[1180px] px-8 pb-12 pt-[54px]">
      <div class="mb-[22px] flex items-center gap-2.5 text-[13px] text-muted">
        <a href={href("/")} class="no-underline text-muted">首頁</a>
        <span>/</span>
        <span class="text-ink">{cat.game}</span>
      </div>
      <div class="text-[11px] font-bold uppercase tracking-[2px] text-accent">
        {cat.en} · 技巧分類
      </div>
      <h1 class="mb-[18px] mt-3.5 font-serif text-[46px] font-medium leading-[1.14] text-ink">
        {cat.game}
      </h1>
      <p class="max-w-[62ch] text-lg leading-[1.65] text-text">{cat.desc}</p>
    </div>
  </section>

  {/* 版本提醒 */}
  <section class="mx-auto max-w-[1180px] px-8 pb-3 pt-9">
    <div
      class="flex items-start gap-3 rounded-[14px] border border-border-strong bg-surface px-[22px] py-[18px]"
    >
      <span class="mt-px flex-none text-accent">
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 3 L22 20 L2 20 Z"></path>
          <line x1="12" y1="10" x2="12" y2="14"></line>
          <circle cx="12" cy="17.4" r="0.6" fill="currentColor"></circle>
        </svg>
      </span>
      <div>
        <div class="mb-[5px] text-[11px] font-bold uppercase tracking-[1.2px] text-accent">
          版本提醒 · NOTE
        </div>
        <p class="text-sm leading-[1.6] text-text">{cat.tip}</p>
      </div>
    </div>
  </section>

  {/* 分類網格 */}
  <section class="mx-auto max-w-[1180px] px-8 pb-20 pt-[30px]">
    <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-[18px]">
      {cat.cats.map((item) => <CategoryCard item={item} />)}
    </div>
  </section>
</BaseLayout>
