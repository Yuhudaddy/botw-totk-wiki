---
import { href } from "../lib/url";
import type { CategoryItem } from "../data/categories";

interface Props {
  item: CategoryItem;
}
const { item } = Astro.props;

// 決定連結目的地：有 article 連攻略頁，有 tag 連影片總覽篩選，否則不可點。
let link: string | null = null;
if (item.articleSlug) link = href(`/article/${item.articleSlug}`);
else if (item.tag) link = href(`/videos?tag=${encodeURIComponent(item.tag)}`);

const isActive = item.status === "active";
const Tag = link ? "a" : "div";
---

<Tag
  href={link ?? undefined}
  class={`flex h-full flex-col gap-2.5 rounded-2xl border border-border-soft bg-surface px-6 pb-[22px] pt-6 no-underline ${
    link ? "cursor-pointer" : "cursor-default"
  }`}
>
  <div class="flex items-center justify-between">
    <span class="font-serif text-[15px] font-medium text-accent">{item.no}</span>
    {
      isActive ? (
        <span class="rounded-full bg-[rgba(201,100,66,0.13)] px-2.5 py-[3px] text-xs font-semibold text-accent">
          進行中
        </span>
      ) : (
        <span class="rounded-full bg-sand px-2.5 py-[3px] text-xs font-medium text-muted">
          建置中
        </span>
      )
    }
  </div>
  <div class="font-serif text-xl font-medium leading-[1.3] text-ink">{item.title}</div>
  <p class="text-sm leading-[1.6] text-text">{item.desc}</p>
  <div class="mt-auto pt-2 text-[13px] text-muted">{item.meta}</div>
</Tag>
