---
import { navItems, SITE } from "../data/site";
import { href } from "../lib/url";
import BrandMark from "./BrandMark.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  active?: string;
}
const { active = "" } = Astro.props;
const videosUrl = href("/videos");
---

<header class="sticky top-0 z-50 border-b border-border-soft bg-bg">
  <div
    class="r-navbar mx-auto flex h-16 max-w-[1180px] items-center gap-[26px] px-8"
  >
    <a href={href("/")} class="flex items-center gap-2.5 no-underline">
      <BrandMark />
      <span class="font-serif text-lg font-medium text-ink">{SITE.shortTitle}</span>
    </a>

    <nav class="r-navlist ml-1.5 flex gap-1">
      {
        navItems.map((n) => {
          const isActive = n.match === active;
          return (
            <a
              href={href(n.path)}
              class={`rounded-lg px-3 py-2 text-[15px] no-underline ${
                isActive
                  ? "bg-sand font-medium text-ink"
                  : "font-normal text-text"
              }`}
            >
              {n.label}
            </a>
          );
        })
      }
    </nav>

    <div class="r-navactions ml-auto flex items-center gap-2.5">
      <div
        class="r-navsearch relative flex w-[300px] items-center rounded-[10px] border border-border-strong bg-surface transition-colors focus-within:border-brand"
        data-videos-url={videosUrl}
      >
        <input
          id="nav-search"
          type="text"
          placeholder="搜尋技巧…"
          autocomplete="off"
          class="w-full bg-transparent py-2 pl-3.5 pr-1 text-sm text-ink outline-none placeholder:text-muted"
        />
        <button
          id="nav-search-btn"
          type="button"
          aria-label="搜尋"
          class="flex flex-none cursor-pointer items-center px-3 py-2 text-muted transition-colors hover:text-brand"
        >
          <svg
            viewBox="0 0 24 24"
            width="15"
            height="15"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </div>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  @media (max-width: 820px) {
    .r-navbar {
      height: auto;
      flex-wrap: wrap;
      align-items: center;
      padding: 10px 18px;
      gap: 0;
    }
    /* Row 1 右側：ThemeToggle 推到最右，與 Logo 同行 */
    .r-navactions {
      order: 2;
      margin-left: auto;
    }
    /* Row 2：nav 佔滿整行，等寬不換行讓各分頁平均分佈 */
    .r-navlist {
      order: 3;
      width: 100%;
      margin-left: 0;
      padding: 6px 0 2px;
      flex-wrap: nowrap;
      gap: 2px;
    }
    .r-navlist a {
      flex: 1 1 0;
      min-width: 0;
      text-align: center;
      font-size: 13px;
      padding: 6px 2px;
      white-space: nowrap;
    }
    .r-navsearch {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var container = document.querySelector('[data-videos-url]');
    var input = document.getElementById('nav-search');
    var btn = document.getElementById('nav-search-btn');
    if (!container || !input || !btn) return;
    var videosUrl = container.getAttribute('data-videos-url');

    function go() {
      var q = input.value.trim();
      if (!q) return;
      window.location.href = videosUrl + '?search=' + encodeURIComponent(q);
    }

    btn.addEventListener('click', go);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') go();
    });
  })();
</script>
