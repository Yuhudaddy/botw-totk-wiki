---
import { navItems, SITE } from "../data/site";
import { href } from "../lib/url";
import BrandMark from "./BrandMark.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  active?: string;
}
const { active = "" } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-border-soft bg-bg">
  <div
    class="r-navbar mx-auto flex h-16 max-w-[1180px] items-center gap-[26px] px-8"
  >
    <a href={href("/")} class="flex items-center gap-2.5 no-underline">
      <BrandMark />
      <span class="font-serif text-lg font-medium text-ink">{SITE.shortTitle}</span>
    </a>

    <nav class="ml-1.5 flex gap-1">
      {
        navItems.map((n) => {
          const isActive = n.match === active;
          return (
            <a
              href={href(n.path)}
              class={`rounded-lg px-3 py-2 text-[15px] no-underline ${
                isActive
                  ? "bg-sand font-medium text-ink"
                  : "font-normal text-text"
              }`}
            >
              {n.label}
            </a>
          );
        })
      }
    </nav>

    <div class="ml-auto flex items-center gap-2.5">
      <a
        href={href("/tags")}
        class="r-navsearch flex w-[300px] items-center gap-2 rounded-[10px] border border-border-strong bg-surface px-3.5 py-2 text-sm text-muted no-underline transition-colors hover:border-brand"
      >
        <svg
          viewBox="0 0 24 24"
          width="15"
          height="15"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        搜尋技巧…
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  @media (max-width: 600px) {
    .r-navbar {
      height: auto;
      flex-wrap: wrap;
      padding: 11px 18px;
      gap: 6px 14px;
    }
    .r-navsearch {
      display: none;
    }
  }
</style>
