---
import { SITE } from "../data/site";
import BrandMark from "./BrandMark.astro";
---

<footer class="border-t border-border-soft bg-surface">
  <div
    class="mx-auto flex max-w-[1180px] flex-wrap items-start justify-between gap-7 px-8 py-[42px]"
  >
    <div>
      <div class="mb-3 flex items-center gap-2.5">
        <BrandMark box={26} size={14} radius={7} />
        <span class="font-serif text-[17px] font-medium text-ink">{SITE.shortTitle}</span>
      </div>
      <p class="max-w-[44ch] text-sm leading-relaxed text-muted">
        薩爾達傳說 BotW / TotK 技巧與 Glitch 攻略
      </p>
      <p class="mt-3.5 text-[13px] text-muted">
        © 2026 {SITE.author} · 內容整理自個人 YouTube 頻道
      </p>
    </div>
    <div class="flex gap-2.5">
      <a
        href={SITE.youtube}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-[9px] bg-surface-2 px-4 py-2.5 text-sm font-medium text-ink no-underline shadow-[0_0_0_1px_var(--border-strong)]"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
        </svg>
        YouTube 頻道
      </a>
      <a
        href={SITE.discord}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-[9px] bg-surface-2 px-4 py-2.5 text-sm font-medium text-ink no-underline shadow-[0_0_0_1px_var(--border-strong)]"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.369A19.79 19.79 0 0 0 15.432 3a13.6 13.6 0 0 0-.617 1.265 18.27 18.27 0 0 0-5.633 0A13 13 0 0 0 8.565 3 19.74 19.74 0 0 0 3.677 4.37C.582 8.97-.258 13.456.162 17.88a19.9 19.9 0 0 0 6.064 3.06c.488-.665.92-1.37 1.293-2.11a13 13 0 0 1-2.036-.977c.171-.125.338-.255.5-.39a14.2 14.2 0 0 0 12.034 0c.164.14.331.27.5.39-.65.385-1.334.712-2.04.978.373.74.806 1.445 1.292 2.11a19.8 19.8 0 0 0 6.067-3.06c.5-5.13-.838-9.575-3.515-13.512ZM8.02 15.158c-1.182 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.335-.955 2.42-2.157 2.42Zm7.975 0c-1.183 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.335-.946 2.42-2.157 2.42Z"></path>
        </svg>
        Discord 社群
      </a>
    </div>
  </div>
</footer>
