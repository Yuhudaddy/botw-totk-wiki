200b\u6b78\u4f86\u200b\u7684\u200b\u865b\u5316\u200b\u88dd\u5099\u200b\uff1a\u200b\u7121\u9650\u200b\u8010\u4e45\u200b\u3001\u200b\u8907\u200b\u88fd\u200b\u3001\u200b\u7121\u9650\u5f48\u200b\u7c27\u200b\u706b\u7bad\u200b\u76fe\u200b\u7b49\u200b\u3002</p> <p>\u200b\u67e5\u770b\u200b\u5206\u985e\u200b \u2192</p> </li> <li> <p> \u200b\u9918\u6599\u200b\u5132\u5b58\u200b Fuse Storage</p> <p>\u200b\u5c07\u9918\u6599\u200b\u72c0\u614b\u200b\u5132\u5b58\u200b\u4ee5\u9054\u6210\u200b\u5404\u7a2e\u200b\u6548\u679c\u200b\u7684\u200b\u57fa\u790e\u200b\u6280\u5de7\u200b\u3002</p> <p>\u200b\u67e5\u770b\u200b\u5206\u985e\u200b \u2192</p> </li> <li> <p> \u200b\u8de8\u6a94\u200b\u7e7c\u627f\u200b PSLOT</p> <p>\u200b\u6c38\u4e45\u200b\u8de8\u6a94\u200b\u7e7c\u627f\u200b\uff08Permanent Save Load Object Transfer\uff09\u3002</p> <p>\u200b\u5206\u985e\u200b\u5efa\u7f6e\u200b\u4e2d\u200b\uff0c\u200b\u656c\u8acb\u200b\u671f\u5f85\u200b</p> </li> <li> <p> \u200b\u901f\u901a\u200b / \u200b\u932f\u50b3\u200b</p> <p>\u200b\u5e8f\u7ae0\u200b\u5927\u5e2b\u200b\u528d\u200b\uff08MsgNotFound\uff09\u3001\u200b\u6307\u6a19\u200b\u932f\u50b3\u200b\uff08Index Wrong Warp\uff09\u200b\u7b49\u200b\u3002</p> <p>\u200b\u5206\u985e\u200b\u5efa\u7f6e\u200b\u4e2d\u200b\uff0c\u200b\u656c\u8acb\u200b\u671f\u5f85\u200b</p> </li> <li> <p> \u200b\u5de6\u7d0d\u200b\u70cf\u88dd\u7f6e\u200b Zonai</p> <p>\u200b\u53e3\u888b\u200b\u706b\u7bad\u200b\u3001GAS\u3001ARAZ\u3001\u200b\u7c73\u6d85\u200b\u9b6f\u76f8\u95dc\u200b\u6280\u5de7\u200b\u3002</p> <p>\u200b\u5206\u985e\u200b\u5efa\u7f6e\u200b\u4e2d\u200b\uff0c\u200b\u656c\u8acb\u200b\u671f\u5f85\u200b</p> </li> <li> <p> \u200b\u4e26\u5217\u200b Zuggle</p> <p>\u200b\u518d\u200b\u540c\u6b65\u200b\u4e26\u5217\u200b\u3001\u200b\u7c73\u6d85\u200b\u9b6f\u5730\u5716\u200b\u4e26\u5217\u200b\u7b49\u200b\u4e26\u5217\u200b\u6280\u5de7\u200b\u3002</p> <p>\u200b\u5206\u985e\u200b\u5efa\u7f6e\u200b\u4e2d\u200b\uff0c\u200b\u656c\u8acb\u200b\u671f\u5f85\u200b</p> </li> </ul> <p>\u200b\u60f3\u200b\u65b0\u589e\u200b\u5206\u985e\u200b\uff1f</p> <p>\u200b\u5206\u985e\u200b\u7531\u200b\u4f60\u200b\u81ea\u884c\u200b\u5b9a\u7fa9\u200b\u3002\u200b\u65b0\u589e\u200b\u65b9\u5f0f\u200b\u8acb\u898b\u200b \u200b\u5982\u4f55\u200b\u65b0\u589e\u200b\u653b\u7565\u200b\uff1a\u200b\u8907\u200b\u88fd\u200b\u7bc4\u200b\u672c\u200b\u3001\u200b\u586b\u5165\u200b\u5f71\u7247\u200b ID \u200b\u8207\u200b\u6b65\u9a5f\u200b\uff0c\u200b\u653e\u9032\u200b\u5c0d\u200b\u61c9\u200b\u8cc7\u6599\u593e\u200b\u5373\u53ef\u200b\u3002</p>"},{"location":"totk/fuse-storage/","title":"\u9918\u6599\u200b\u5132\u5b58\u200b Fuse Storage","text":"<p>\u200b\u5c07\u9918\u6599\u200b\uff08Fuse\uff09\u200b\u72c0\u614b\u200b\u5132\u5b58\u200b\u4ee5\u9054\u6210\u200b\u5404\u7a2e\u200b\u6548\u679c\u200b\u7684\u200b\u57fa\u790e\u200b\u6280\u5de7\u200b\uff0c\u200b\u662f\u200b\u8a31\u591a\u200b\u9032\u968e\u200b\u6d41\u7a0b\u200b\u7684\u200b\u524d\u7f6e\u200b\u3002</p> <ul> <li> <p></p> <p>\u200b\u9918\u6599\u200b\u5132\u5b58\u200b \u200b\u57fa\u790e\u200b \u200b\u738b\u570b\u200b\u4e4b\u6dda\u200b \u30fb \u200b\u4e0d\u5ee2\u8a71\u200b02\uff08NS2\u200b\u7248\u200b\uff09\u30fb \u200b\u9069\u7528\u200b \uff5e1.4.3</p> </li> </ul>"},{"location":"totk/fuse-storage/fuse-storage-basics/","title":"\u9918\u6599\u200b\u5132\u5b58\u200b Fuse Storage \u2014 \u200b\u57fa\u790e","text":"<p>\u300c\u200b\u9918\u6599\u200b\u5132\u5b58\u200b (Fuse Storage)\u300d\u200b\u7684\u200b\u57fa\u790e\u200b\u539f\u7406\u200b\u8207\u200b\u64cd\u4f5c\u200b\u3002</p> \u200b\u9069\u7528\u200b\u7248\u672c\u200b \u200b\u96e3\u5ea6\u200b \u200b\u5f71\u7247\u200b \u200b\u738b\u570b\u200b\u4e4b\u6dda\u200b \uff5e1.4.3 \u200b\u5165\u9580\u200b \u25b6 \u200b\u5728\u200b YouTube \u200b\u89c0\u770b\u200b <p>\u200b\u7bc4\u4f8b\u200b\u9801\u200b\uff1a\u200b\u6b65\u9a5f\u200b\u5167\u5bb9\u5f85\u200b\u88dc\u200b</p> <p>\u200b\u672c\u9801\u200b\u5f71\u7247\u200b\u8207\u200b\u6a19\u984c\u200b\u70ba\u200b\u771f\u5be6\u200b\u5167\u5bb9\u200b\uff0c\u200b\u4e0b\u65b9\u200b\u6b65\u9a5f\u200b\u70ba\u200b\u7bc4\u672c\u200b\u4f54\u4f4d\u200b\u3002\u200b\u8acb\u200b\u4f9d\u200b\u5f71\u7247\u200b\u5167\u5bb9\u200b\u6574\u7406\u200b\u5be6\u969b\u200b\u64cd\u4f5c\u200b\u6b65\u9a5f\u200b\u5f8c\u200b\uff0c\u200b\u522a\u9664\u200b\u6b64\u200b\u63d0\u9192\u200b\u3002</p>","tags":["\u738b\u570b\u4e4b\u6dda","\u5132\u5b58\u985e","\u5165\u9580"]},{"location":"totk/fuse-storage/fuse-storage-basics/#_1","title":"\u9019\u662f\u200b\u4ec0\u9ebc","text":"","tags":["\u738b\u570b\u4e4b\u6dda","\u5132\u5b58\u985e","\u5165\u9580"]},{"location":"totk/fuse-storage/fuse-storage-basics/#_2","title":"\u6b65\u9a5f","text":"","tags":["\u738b\u570b\u4e4b\u6dda","\u5132\u5b58\u985e","\u5165\u9580"]},{"location":"totk/fuse-storage/fuse-storage-basics/#_3","title":"\u6ce8\u610f\u200b\u4e8b\u9805","text":"<p>\ud83d\udcfa \u200b\u5f71\u7247\u200b\u4f86\u6e90\u200b\uff1aYouTube \u2014 @zb_yuhudaddy</p>","tags":["\u738b\u570b\u4e4b\u6dda","\u5132\u5b58\u985e","\u5165\u9580"]},{"location":"totk/void-dip-di/","title":"\u865b\u5316\u200b\u88dd\u5099\u200b Void Dip / DI","text":"<p>\u200b\u865b\u7a7a\u6b21\u200b\u5143\u200b\u6b78\u4f86\u200b\u7684\u200b\u300c\u200b\u865b\u5316\u200b\u88dd\u5099\u200b\u300d\u200b\u539f\u7406\u200b\u8207\u200b\u5e38\u7528\u200b\u6b65\u9a5f\u200b\u3002\u200b\u53ef\u9054\u6210\u200b\u7121\u9650\u200b\u8010\u4e45\u200b\u3001\u200b\u8907\u200b\u88fd\u200b\u3001\u200b\u7121\u9650\u5f48\u200b\u7c27\u200b\u706b\u7bad\u200b\u76fe\u200b\u7b49\u200b\u6548\u679c\u200b\u3002</p> <ul> <li> <p></p> <p>\u200b\u539f\u200b\u7406\u89e3\u200b\u8aaa\u200b\u8207\u200b\u5e38\u7528\u200b\u6b65\u9a5f\u200b\u793a\u7bc4\u200b \u200b\u738b\u570b\u200b\u4e4b\u6dda\u200b \u30fb \u200b\u756a\u5916\u200b21 \u30fb \u200b\u9069\u7528\u200b 1.2.1\uff5e</p> </li> <li> <p></p> <p>\u200b\u602a\u6301\u200b\u865b\u5316\u200b\u53e3\u888b\u200b\u706b\u7bad\u200b Enemy DI IPR \u200b\u738b\u570b\u200b\u4e4b\u6dda\u200b \u30fb \u200b\u756a\u5916\u200b23\uff08\u200b\u6703\u54e1\u200b\uff09</p> </li> </ul>"},{"location":"totk/void-dip-di/void-dip-di-basics/","title":"\u865b\u5316\u200b\u88dd\u5099\u200b Void Dip &amp; DI \u2014 \u200b\u539f\u7406\u200b\u8207\u200b\u5e38\u7528\u200b\u6b65\u9a5f","text":"<p>\u200b\u7121\u9650\u200b\u8010\u4e45\u200b\uff06\u200b\u8907\u200b\u88fd\u200b\uff06\u200b\u7121\u9650\u5f48\u200b\u7c27\u200b\u706b\u7bad\u200b\u76fe\u200b\uff01\u200b\u865b\u7a7a\u6b21\u200b\u5143\u200b\u6b78\u4f86\u200b\u7684\u200b\u300c\u200b\u865b\u5316\u200b\u88dd\u5099\u200b (Void Dip &amp; DI)\u300d\u200b\u539f\u200b\u7406\u89e3\u200b\u8aaa\u200b\u8207\u200b\u5e38\u7528\u200b\u6b65\u9a5f\u200b\u793a\u7bc4\u200b\u3002</p> \u200b\u9069\u7528\u200b\u7248\u672c\u200b \u200b\u96e3\u5ea6\u200b \u200b\u5f71\u7247\u200b \u200b\u738b\u570b\u200b\u4e4b\u6dda\u200b 1.2.1\uff5e \u200b\u9032\u968e\u200b \u25b6 \u200b\u5728\u200b YouTube \u200b\u89c0\u770b\u200b <p>\u200b\u7bc4\u4f8b\u200b\u9801\u200b\uff1a\u200b\u6b65\u9a5f\u200b\u5167\u5bb9\u5f85\u200b\u88dc\u200b</p> <p>\u200b\u672c\u9801\u200b\u5f71\u7247\u200b\u8207\u200b\u6a19\u984c\u200b\u70ba\u200b\u771f\u5be6\u200b\u5167\u5bb9\u200b\uff0c\u200b\u4e0b\u65b9\u200b\u6b65\u9a5f\u200b\u70ba\u200b\u7bc4\u672c\u200b\u4f54\u4f4d\u200b\u3002\u200b\u8acb\u200b\u4f9d\u200b\u5f71\u7247\u200b\u5167\u5bb9\u200b\u6574\u7406\u200b\u5be6\u969b\u200b\u64cd\u4f5c\u200b\u6b65\u9a5f\u200b\u5f8c\u200b\uff0c\u200b\u522a\u9664\u200b\u6b64\u200b\u63d0\u9192\u200b\u3002</p>","tags":["\u738b\u570b\u4e4b\u6dda","\u865b\u5316\u985e","\u9032\u968e"]},{"location":"totk/void-dip-di/void-dip-di-basics/#_1","title":"\u9019\u662f\u200b\u4ec0\u9ebc","text":"","tags":["\u738b\u570b\u4e4b\u6dda","\u865b\u5316\u985e","\u9032\u968e"]},{"location":"totk/void-dip-di/void-dip-di-basics/#_2","title":"\u524d\u7f6e\u200b\u6e96\u5099","text":"","tags":["\u738b\u570b\u4e4b\u6dda","\u865b\u5316\u985e","\u9032\u968e"]},{"location":"totk/void-dip-di/void-dip-di-basics/#_3","title":"\u5e38\u7528\u200b\u6b65\u9a5f","text":"","